OPENAI_API_KEY=sk-proj-...

ADMIN_USER=admin
ADMIN_PASSWORD=your-password-here

# URL del webhook CRM (Make, Zapier, HubSpot...). Dejar vacío para omitir el envío externo.
CRM_WEBHOOK_URL=https://webhook.site/your-uuid

# ID del calendario de Google donde se crean las citas automáticas
GOOGLE_CALENDAR_ID=your-calendar@gmail.com

# Orígenes permitidos por CORS (separados por coma). En producción: https://tudominio.com
# Si no se define, se acepta cualquier origen (solo válido en desarrollo).
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Poner a "true" solo en producción detrás de un proxy que rellene X-Forwarded-For de forma
# fiable (p.ej. Render). En local o sin proxy, dejar en false (o sin definir).
TRUST_PROXY=false

# Tope de gasto (USD) por conversación en /chat antes de dejar de llamar a OpenAI e invitar
# a llamar por teléfono.
CHAT_MAX_COSTE_USD=0.50

# Días de retención de conversaciones antes de purgarlas automáticamente (RGPD).
RETENCION_DIAS=730

# Clave secreta para firmar tokens de sesión HMAC. Generar con:
# python -c "import secrets; print(secrets.token_hex(32))"
# Si no se define, el sistema acepta cualquier user_id (solo válido en desarrollo).
SECRET_KEY=cambia-esto-por-una-cadena-aleatoria-de-64-chars

# Alertas de email al recibir un lead nuevo (opcional).
# EMAIL_PASSWORD debe ser una App Password de Gmail (no la contraseña normal).
# Generar en: myaccount.google.com → Seguridad → Contraseñas de aplicaciones
EMAIL_SENDER=palcarazsa06@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_DESTINATARIO=palcarazsa06@gmail.com

# URL del panel de administración, usada en el cuerpo del email de alerta de lead.
# En producción: https://solsurestesolar.com/admin
PANEL_URL=http://localhost:8000/admin
